{
  "name": "@lirdle/web",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "pnpm run build:server && pnpm run build:client",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "tsc -p tsconfig.client.json",
    "dev": "concurrently -k -n client,server \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "tsc -w -p tsconfig.client.json --preserveWatchOutput",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.4.1",
    "@lirdle/db": "workspace:*",
    "@lirdle/logger": "workspace:*",
    "cloudflared": "^0.7.1",
    "cors": "^2.8.6",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1"
  }
}
